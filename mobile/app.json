{
  "expo": {
    "name": "SkillLearn",
    "owner": "umeshchandel551",
    "slug": "skilllearn",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "skilllearn",
    "newArchEnabled": true,
    "userInterfaceStyle": "automatic",
    "icon": "./assets/splashscreen_logo.png",
    "splash": {
      "image": "./assets/splashscreen_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skilllearn.app",
      "splash": {
        "image": "./assets/splashscreen_logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#F8FAFC"
      }
    },
    "android": {
      "package": "com.skilllearn.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "skilllearn"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "splash": {
        "image": "./assets/splashscreen_logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#F8FAFC"
      }
    },
    "extra": {
      "apiUrl": "https://skillup-dwny.onrender.com/api",
      "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "922334979850-tea7g0dtp9em95i6rt5ugfiks95356hi.apps.googleusercontent.com",
      "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "922334979850-aefgpkep0bcia9hl2o14g8sm2pus2hnn.apps.googleusercontent.com",
      "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "922334979850-dhiiqif44arcqjp360a51e9020bbskqc.apps.googleusercontent.com",
      "eas": {
        "projectId": "38670d1f-a8d1-4f54-bab7-cc178f533b28"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "expo-splash-screen"
    ]
  }
}

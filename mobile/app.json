{
  "expo": {
    "name": "SkillLearn",
    "owner": "umeshchandel551",
    "slug": "skilllearn",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "skilllearn",
    "newArchEnabled": true,
    "userInterfaceStyle": "automatic",
    "icon": "./assets/splashscreen_logo.png",
    "splash": {
      "image": "./assets/splashscreen_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skilllearn.app",
      "splash": {
        "image": "./assets/splashscreen_logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#F8FAFC"
      }
    },
    "android": {
      "package": "com.skilllearn.app",
      "splash": {
        "image": "./assets/splashscreen_logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#F8FAFC"
      }
    },
    "extra": {
      "apiUrl": "https://skillup-dwny.onrender.com/api",
      "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "461555492381-stutvtqq8ovgs14i3pr8v89n65nod5ru.apps.googleusercontent.com",
      "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "461555492381-2u27hogc5v5cagiaa8vbcfeiks03rs27.apps.googleusercontent.com",
      "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "461555492381-vl6lg3op0dt7fm8h2qoekv0ltr2tfc8j.apps.googleusercontent.com",
      "eas": {
        "projectId": "38670d1f-a8d1-4f54-bab7-cc178f533b28"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "expo-splash-screen"
    ]
  }
}
